{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "PORT", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true
    },
    "format": {
      "cache": true
    }
  }
}
