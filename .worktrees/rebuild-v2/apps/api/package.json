{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify --sourcemap src/index.ts --outfile dist/api-server",
    "audit:export": "bun run src/modules/audit/export-worker.ts",
    "lint": "oxlint --fix --deny-warnings",
    "format": "oxfmt --write .",
    "typecheck": "tsgo --noEmit",
    "test": "SKIP_ENV_VALIDATION=true bun test"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "0.1.10",
    "@elysiajs/cors": "catalog:api",
    "@elysiajs/openapi": "catalog:api",
    "@google-analytics/data": "catalog:analytics",
    "@google/generative-ai": "catalog:analytics",
    "@sinclair/typebox": "catalog:api",
    "@workspace/auth": "workspace:*",
    "@workspace/common": "workspace:*",
    "@workspace/crypto": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/dosespot": "workspace:*",
    "@workspace/env": "workspace:*",
    "@workspace/notifications": "workspace:*",
    "@workspace/queue": "workspace:*",
    "drizzle-orm": "catalog:db",
    "elysia": "catalog:api",
    "elysia-helmet": "3.1.0",
    "elysia-http-exception": "catalog:api",
    "elysia-ip": "1.1.0",
    "elysia-rate-limit": "4.6.0",
    "elysia-requestid": "1.0.9",
    "elysia-xss": "1.0.4",
    "pino": "10.3.1",
    "pino-roll": "4.0.0",
    "postgres": "catalog:db",
    "stripe": "catalog:payments"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:dev",
    "bun-types": "catalog:dev",
    "oxlint": "catalog:dev",
    "pino-pretty": "13.1.3"
  }
}
